{
  "network": {
    "allowedDomains": [
      "api.anthropic.com",

      "registry.npmjs.org",
      "pypi.org",
      "*.pypi.org",
      "files.pythonhosted.org",

      "api.nuget.org",
      "*.nuget.org",
      "dist.nuget.org",
      "globalcdn.nuget.org",
      "symbols.nuget.org",

      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com",

      "docs.anthropic.com",
      "code.claude.com",
      "developer.mozilla.org",
      "docs.python.org",
      "docs.npmjs.com",
      "stackoverflow.com",
      "learn.microsoft.com",
      "*.learn.microsoft.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "allowWrite": [
      ".",
      "~/.claude",
      "~/.claude.json",
      "/tmp"
    ],
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg",
      "~/.npmrc",
      "~/.pypirc",
      "~/.netrc",
      "~/.docker/config.json",
      "~/.nuget/NuGet/NuGet.Config",
      ".env"
    ],
    "denyWrite": [
      ".env"
    ]
  }
}
